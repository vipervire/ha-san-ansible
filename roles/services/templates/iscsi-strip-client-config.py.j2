#!/usr/bin/env python3
# Managed by Ansible — Remove client-facing entries from local saveconfig.json
#
# Strips zvol backstores and the client target IQN from saveconfig.json, leaving
# only backend entries (disk backstores + replication target). This prevents stale
# client LUNs from loading at boot — the sync script restores the exact config
# from shared ZFS storage after pool import instead.
#
# Idempotent: only modifies the file if client entries are actually present.
#
# IMPORTANT: Run BEFORE enabling iscsi-config-sync.path to prevent the watcher
# from saving an empty (just-stripped) client config over the shared copy.
#
# Usage: /root/iscsi-strip-client-config.py

import json
import os
import sys

SAVECONFIG_PATH = "{{ _iscsi_saveconfig_path }}"
CLIENT_IQN      = "{{ iscsi_client_iqn }}"

if not os.path.exists(SAVECONFIG_PATH):
    print(f"NOTE: {SAVECONFIG_PATH} not found — nothing to strip")
    sys.exit(0)

with open(SAVECONFIG_PATH) as f:
    config = json.load(f)

original_bs_count     = len(config.get("storage_objects", []))
original_target_count = len(config.get("targets", []))

# Keep only backend backstores (disk devices — not zvols)
backend_storage = [
    obj for obj in config.get("storage_objects", [])
    if not obj.get("dev", "").startswith("/dev/zvol/")
]

# Keep only non-client targets
backend_targets = [
    t for t in config.get("targets", [])
    if t.get("wwn") != CLIENT_IQN
]

stripped_bs      = original_bs_count - len(backend_storage)
stripped_targets = original_target_count - len(backend_targets)

if stripped_bs == 0 and stripped_targets == 0:
    print("No client entries found in saveconfig.json — nothing to strip")
    sys.exit(0)

config["storage_objects"] = backend_storage
config["targets"]         = backend_targets

# Atomic write
tmp_path = SAVECONFIG_PATH + ".strip-tmp"
try:
    with open(tmp_path, "w") as f:
        json.dump(config, f, indent=2)
    os.rename(tmp_path, SAVECONFIG_PATH)
except Exception as e:
    if os.path.exists(tmp_path):
        os.unlink(tmp_path)
    print(f"ERROR: Failed to write {SAVECONFIG_PATH}: {e}", file=sys.stderr)
    sys.exit(1)

print(f"Stripped {stripped_bs} client backstore(s) and "
      f"{stripped_targets} client target(s) from local saveconfig.json")
print(f"Remaining: {len(backend_storage)} backend backstore(s), "
      f"{len(backend_targets)} backend target(s)")
