{% set iscsi_vlans = client_vlans | selectattr('services', 'contains', 'iscsi') | list %}
# Managed by Ansible — iSCSI CHAP credentials for this node
# Encrypted with OpenSSL AES-256-CBC using /etc/machine-id as passphrase.
# Machine-specific: this file is useless on any other node.
# To rotate: re-run Ansible (services tag) to deploy a new encrypted file.

# Per-initiator CHAP (ACL-mode VLANs)
# Key format: "<tpg_num>:<initiator_iqn>"
declare -A CHAP_USER CHAP_PASS
{% for cv in iscsi_vlans %}
{%   set tpg_num = loop.index %}
{%   if not (cv.generate_node_acls | default(false)) %}
{%     set vlan_acls = cv.iscsi_acls if cv.iscsi_acls is defined else iscsi_client_acls %}
{%     for entry in vlan_acls %}
{%       if entry is mapping and entry.chap_password is defined %}
CHAP_USER["{{ tpg_num }}:{{ entry.iqn }}"]="{{ entry.chap_user }}"
CHAP_PASS["{{ tpg_num }}:{{ entry.iqn }}"]="{{ entry.chap_password }}"
{%       endif %}
{%     endfor %}
{%   endif %}
{% endfor %}

# Per-TPG CHAP (generate_node_acls VLANs — all initiators share one credential)
# Key format: "<tpg_num>"
declare -A TPG_CHAP_USER TPG_CHAP_PASS
{% for cv in iscsi_vlans %}
{%   set tpg_num = loop.index %}
{%   if (cv.generate_node_acls | default(false)) and cv.iscsi_chap_user is defined and cv.iscsi_chap_password is defined %}
TPG_CHAP_USER["{{ tpg_num }}"]="{{ cv.iscsi_chap_user }}"
TPG_CHAP_PASS["{{ tpg_num }}"]="{{ cv.iscsi_chap_password }}"
{%   endif %}
{% endfor %}
