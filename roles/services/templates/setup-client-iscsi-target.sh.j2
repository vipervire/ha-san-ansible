#!/bin/bash
# Managed by Ansible — Client-facing LIO iSCSI target setup (per-VLAN TPGs)
# This script is idempotent: safe to re-run. Pacemaker starts/stops the service;
# LIO configuration is persistent across reboots via targetcli saveconfig.
#
# Each iSCSI-enabled client VLAN gets its own TPG with isolated portals, ACLs,
# and LUN mappings. Single-VLAN deployments produce one TPG (tpg1), functionally
# identical to the old single-TPG behavior. TPG numbering follows loop.index
# (first iSCSI VLAN = tpg1, second = tpg2, etc.).
#
# CHAP is enabled per-initiator (ACL mode) or per-TPG (generate_node_acls mode)
# when credentials are present in /root/.iscsi-chap.env.enc.
#
# Re-run after VLAN changes: bash /root/setup-client-iscsi-target.sh
set -euo pipefail
{% set iscsi_vlans = client_vlans | selectattr('services', 'contains', 'iscsi') | list %}
{% set iscsi_vlan_count = iscsi_vlans | length %}
{# Validate multi-VLAN config at template render time — fail clearly rather than silently wrong #}
{% if iscsi_vlan_count > 1 %}
{%   for cv in iscsi_vlans %}
{%     if not (cv.generate_node_acls | default(false)) %}
{%       set _acl_check = cv.iscsi_acls | mandatory("client_vlans['" ~ cv.name ~ "'].iscsi_acls is required when multiple VLANs have iSCSI service and generate_node_acls is not true (prevents cross-VLAN access)") %}
{%     endif %}
{%     set _ds_check  = cv.iscsi_dataset | mandatory("client_vlans['" ~ cv.name ~ "'].iscsi_dataset is required when multiple VLANs have iSCSI service (prevents LUN namespace collisions)") %}
{%   endfor %}
{% endif %}

TARGET_IQN="{{ iscsi_client_iqn }}"
TOTAL_TPGS={{ iscsi_vlan_count }}

# TPG assignments (baked in at Ansible deploy time):
{% for cv in iscsi_vlans %}
#   TPG{{ loop.index }}: VLAN={{ cv.name }}, VIP={{ cv.vip }}, Dataset={{ cv.iscsi_dataset | default(iscsi_client_zvol_dataset) }}
{% endfor %}

echo "=== Configuring client iSCSI target: ${TARGET_IQN} ==="
echo "    iSCSI VLANs: {{ iscsi_vlans | map(attribute='name') | join(', ') }} (${TOTAL_TPGS} TPG(s))"

# ─── Decrypt CHAP credentials ─────────────────────────────────────────────
# CHAP_USER["tpg:iqn"] / CHAP_PASS["tpg:iqn"] — per-initiator (ACL-mode VLANs)
# TPG_CHAP_USER["tpg"] / TPG_CHAP_PASS["tpg"] — per-TPG (generate_node_acls VLANs)
declare -A CHAP_USER CHAP_PASS TPG_CHAP_USER TPG_CHAP_PASS
if [ -f /root/.iscsi-chap.env.enc ]; then
  eval "$(openssl enc -d -aes-256-cbc -pbkdf2 -pass file:/etc/machine-id \
    -in /root/.iscsi-chap.env.enc 2>/dev/null)" || {
    echo "WARNING: Failed to decrypt CHAP credentials — CHAP will not be applied"
  }
fi

# ─── Create target if needed (tpg1 auto-created with target) ──────────────────
if targetcli ls /iscsi/"${TARGET_IQN}" &>/dev/null; then
  echo "Target ${TARGET_IQN} already exists — reconciling TPGs."
else
  targetcli /iscsi create "${TARGET_IQN}"
  echo "  Created target ${TARGET_IQN} (tpg1 auto-created)"
fi

# Remove default 0.0.0.0 portal from tpg1 (created automatically with target)
targetcli /iscsi/"${TARGET_IQN}"/tpg1/portals delete 0.0.0.0 3260 2>/dev/null || true

# ─── Per-VLAN TPG configuration ───────────────────────────────────────────────
{% for cv in iscsi_vlans %}
{% set tpg_num = loop.index %}
{% set vlan_generate_node_acls = cv.generate_node_acls | default(false) %}
{% if not vlan_generate_node_acls %}
{%   set vlan_acls = cv.iscsi_acls if cv.iscsi_acls is defined else iscsi_client_acls %}
{%   set vlan_has_chap = vlan_acls | select('mapping') | selectattr('chap_password', 'defined') | list | length > 0 %}
{% else %}
{%   set vlan_has_chap = cv.iscsi_chap_password is defined %}
{% endif %}

echo ""
echo "--- TPG{{ tpg_num }}: VLAN={{ cv.name }}, VIP={{ cv.vip }} ---"
{% if tpg_num > 1 %}
# Create tpg{{ tpg_num }} if it doesn't exist (tpg1 was auto-created with the target)
if ! targetcli ls /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} &>/dev/null; then
  targetcli /iscsi/"${TARGET_IQN}" create
  # Verify the correct tag was assigned. If a stale higher-numbered TPG exists,
  # LIO assigns the next available index which may not match our expected tpg{{ tpg_num }}.
  if ! targetcli ls /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} &>/dev/null; then
    echo "ERROR: Created a new TPG but tpg{{ tpg_num }} still does not exist."
    echo "       A stale higher-numbered TPG likely caused LIO to assign a different tag."
    echo "       List current TPGs: targetcli ls /iscsi/${TARGET_IQN}/"
    echo "       Remove stale TPGs (clear ACLs, portals, and LUNs first), then re-run."
    exit 1
  fi
  echo "  Created tpg{{ tpg_num }}"
  # Remove default 0.0.0.0 portal from the new TPG
  targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/portals delete 0.0.0.0 3260 2>/dev/null || true
fi
{% endif %}

# Bind portal — only this VLAN's VIP should be in this TPG
if ! targetcli ls /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/portals/"{{ cv.vip }}":3260 &>/dev/null; then
  targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/portals create "{{ cv.vip }}" 3260
  echo "  + Created portal {{ cv.vip }}:3260"
fi

# Remove stale portals (anything that isn't this VLAN's VIP)
while IFS= read -r portal_ip; do
  [ -n "$portal_ip" ] || continue
  if [ "$portal_ip" != "{{ cv.vip }}" ]; then
    echo "  - Removing stale portal ${portal_ip}:3260 from tpg{{ tpg_num }}"
    targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/portals delete "${portal_ip}" 3260
  fi
done < <(targetcli ls /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/portals/ 2>/dev/null \
  | grep -oP '(?<=o- )\d+\.\d+\.\d+\.\d+' || true)

{% if vlan_generate_node_acls %}
# Proxmox compatibility — allow any initiator (no explicit ACLs)
targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} set attribute generate_node_acls=1
targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} set attribute demo_mode_write_protect=0
{% else %}
# Enforce ACL-based access control (no auto-generated ACLs)
targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} set attribute generate_node_acls=0
{% endif %}
{% if vlan_has_chap %}
# Enable CHAP authentication for this VLAN (credentials loaded from encrypted file)
targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} set attribute authentication=1
{% else %}
# No CHAP configured — initiator IQN must match to connect (ACL mode) or any initiator (generate_node_acls)
targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} set attribute authentication=0
{% endif %}

# Enable the TPG (responds to initiator connections and SendTargets discovery)
targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }} enable 2>/dev/null || true

{% if not vlan_generate_node_acls %}
# Add missing ACLs for this VLAN
{% for entry in vlan_acls %}
{% set initiator_iqn = entry.iqn if entry is mapping else entry %}
if ! targetcli ls /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/acls/{{ initiator_iqn }} &>/dev/null; then
  targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/acls create {{ initiator_iqn }}
  echo "  + Added ACL: {{ initiator_iqn }}"
fi
{% if entry is mapping and entry.chap_password is defined %}
# Apply per-initiator CHAP credentials from encrypted file
chap_key="{{ tpg_num }}:{{ initiator_iqn }}"
if [[ "${CHAP_USER[$chap_key]+_}" ]]; then
  # Wrap in single quotes; escape embedded single quotes as '\''.
  _cu="${CHAP_USER[$chap_key]}"
  _cp="${CHAP_PASS[$chap_key]}"
  _chap_cmd="/iscsi/${TARGET_IQN}/tpg{{ tpg_num }}/acls/{{ initiator_iqn }} set auth userid='${_cu//\'/\'\\\'\'}' password='${_cp//\'/\'\\\'\'}'"
  targetcli <<< "$_chap_cmd"
  unset _chap_cmd _cu _cp
fi
{% endif %}
{% endfor %}

# Remove stale ACLs from this TPG (IQNs not in this VLAN's ACL list)
TPG{{ tpg_num }}_DESIRED_ACLS=(
{% for entry in vlan_acls %}
{% set initiator_iqn = entry.iqn if entry is mapping else entry %}
  "{{ initiator_iqn }}"
{% endfor %}
)
while IFS= read -r existing_iqn; do
  [ -n "$existing_iqn" ] || continue
  found=false
  for desired_iqn in "${TPG{{ tpg_num }}_DESIRED_ACLS[@]}"; do
    if [ "$desired_iqn" = "$existing_iqn" ]; then found=true; break; fi
  done
  if [ "$found" = "false" ]; then
    echo "  - Removing stale ACL from tpg{{ tpg_num }}: ${existing_iqn}"
    targetcli /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/acls delete "${existing_iqn}"
  fi
done < <(targetcli ls /iscsi/"${TARGET_IQN}"/tpg{{ tpg_num }}/acls/ 2>/dev/null \
  | grep -oP '(?<=o- )iqn\.[^\s]+' || true)
{% elif vlan_has_chap %}
# TPG-level CHAP — all initiators use the same credential (generate_node_acls mode)
if [[ "${TPG_CHAP_USER[{{ tpg_num }}]+_}" ]]; then
  # Wrap in single quotes; escape embedded single quotes as '\''.
  _cu="${TPG_CHAP_USER[{{ tpg_num }}]}"
  _cp="${TPG_CHAP_PASS[{{ tpg_num }}]}"
  _chap_cmd="/iscsi/${TARGET_IQN}/tpg{{ tpg_num }} set auth userid='${_cu//\'/\'\\\'\'}' password='${_cp//\'/\'\\\'\'}'"
  targetcli <<< "$_chap_cmd"
  unset _chap_cmd _cu _cp
fi
{% endif %}
{% endfor %}

# ─── Warn about stale TPGs (beyond current VLAN count) ────────────────────────
# Auto-deletion requires removing all LUNs, portals, and ACLs first — operator
# should clean up manually when removing an iSCSI VLAN.
echo ""
echo "--- Checking for stale TPGs (beyond tpg${TOTAL_TPGS}) ---"
for tpg_tag in $(targetcli ls /iscsi/"${TARGET_IQN}"/ 2>/dev/null \
  | grep -oP '(?<=o- tpg)\d+' | sort -n || true); do
  if [ "$tpg_tag" -gt "$TOTAL_TPGS" ]; then
    echo "  WARNING: stale tpg${tpg_tag} found — no longer mapped to a VLAN."
    echo "    Disable: targetcli /iscsi/${TARGET_IQN}/tpg${tpg_tag} disable"
    echo "    Then remove ACLs, portals, and LUNs before deleting the TPG."
  fi
done

# ─── Write per-VLAN ACL files to shared storage ────────────────────────────────
# sync-iscsi-luns.sh reads acls-<vlan>.conf after pool import to recreate ACLs
# on whichever node becomes active. Edit these files directly to add/remove
# initiators without re-running Ansible.
ACLS_DIR="/{{ zfs_pool_name }}/cluster-config/iscsi"
mkdir -p "${ACLS_DIR}"
{% for cv in iscsi_vlans %}
{% if not (cv.generate_node_acls | default(false)) %}
{% set vlan_acls = cv.iscsi_acls if cv.iscsi_acls is defined else iscsi_client_acls %}
cat > "${ACLS_DIR}/acls-{{ cv.name }}.conf" <<'ACLS_{{ cv.name | upper }}_EOF'
# Managed by Ansible — iSCSI initiator ACLs for VLAN: {{ cv.name }} (TPG{{ loop.index }})
# One IQN per line. Edit to add/remove initiators.
# Changes apply on next failover or: bash /root/sync-iscsi-luns.sh
{% for entry in vlan_acls %}
{% set initiator_iqn = entry.iqn if entry is mapping else entry %}
{{ initiator_iqn }}
{% endfor %}
ACLS_{{ cv.name | upper }}_EOF
chmod 0640 "${ACLS_DIR}/acls-{{ cv.name }}.conf"
echo "ACL list seeded at ${ACLS_DIR}/acls-{{ cv.name }}.conf"
{% endif %}
{% endfor %}

# Write legacy union acls.conf for backward compatibility (all VLANs combined)
cat > "${ACLS_DIR}/acls.conf" <<'UNION_ACLS_EOF'
# Managed by Ansible — union ACL list (all iSCSI VLANs combined)
# Per-VLAN files: acls-<vlan-name>.conf (preferred for per-VLAN sync)
{% for cv in iscsi_vlans %}
{% if not (cv.generate_node_acls | default(false)) %}
{% set vlan_acls = cv.iscsi_acls if cv.iscsi_acls is defined else iscsi_client_acls %}
# VLAN: {{ cv.name }} (TPG{{ loop.index }})
{% for entry in vlan_acls %}
{% set initiator_iqn = entry.iqn if entry is mapping else entry %}
{{ initiator_iqn }}
{% endfor %}
{% endif %}
{% endfor %}
UNION_ACLS_EOF
chmod 0640 "${ACLS_DIR}/acls.conf"

targetcli saveconfig
echo ""
echo "=== Client iSCSI target configured successfully ==="
