#!/bin/bash
# Managed by Ansible — Client-facing LIO iSCSI target setup
# This script is idempotent: safe to re-run. Pacemaker starts/stops the service;
# LIO configuration is persistent across reboots via targetcli saveconfig.
set -euo pipefail

TARGET_IQN="{{ iscsi_client_iqn }}"

echo "=== Configuring client iSCSI target: ${TARGET_IQN} ==="

# Check if target already exists
if targetcli ls /iscsi/"${TARGET_IQN}" &>/dev/null 2>&1; then
  echo "Target ${TARGET_IQN} already exists — updating portals and ACLs."
  TARGET_EXISTS=true
else
  TARGET_EXISTS=false
fi

if [[ "${TARGET_EXISTS}" == "false" ]]; then
  # Create the iSCSI target
  targetcli /iscsi create "${TARGET_IQN}"

  # Remove default 0.0.0.0 portal
  targetcli /iscsi/"${TARGET_IQN}"/tpg1/portals delete 0.0.0.0 3260 2>/dev/null || true
fi

# ─── Bind portals to iSCSI-enabled client VLAN VIPs ──────────────────────────
# Portals are bound to VIPs (not 0.0.0.0) so they only respond when VIP is active.
# Requires net.ipv4.ip_nonlocal_bind=1 so LIO can bind before Pacemaker assigns VIPs.
# Desired portal IPs (iSCSI-enabled client VLANs only)
DESIRED_PORTALS=(
{% for cv in client_vlans %}
{% if 'iscsi' in cv.services %}
  "{{ cv.vip }}"
{% endif %}
{% endfor %}
)

# Add missing portals
for vip in "${DESIRED_PORTALS[@]}"; do
  if ! targetcli ls /iscsi/"${TARGET_IQN}"/tpg1/portals/"${vip}":3260 &>/dev/null 2>&1; then
    targetcli /iscsi/"${TARGET_IQN}"/tpg1/portals create "${vip}" 3260
    echo "  + Created portal ${vip}:3260"
  fi
done

# Remove stale portals (IPs no longer in an iSCSI-enabled VLAN)
while IFS= read -r portal_ip; do
  [ -n "$portal_ip" ] || continue
  found=false
  for vip in "${DESIRED_PORTALS[@]}"; do
    if [ "$vip" = "$portal_ip" ]; then
      found=true
      break
    fi
  done
  if [ "$found" = "false" ]; then
    echo "  - Removing stale portal ${portal_ip}:3260"
    targetcli /iscsi/"${TARGET_IQN}"/tpg1/portals delete "${portal_ip}" 3260
  fi
done < <(targetcli ls /iscsi/"${TARGET_IQN}"/tpg1/portals/ 2>/dev/null | grep -oP '(?<=o- )\d+\.\d+\.\d+\.\d+' || true)

{% if iscsi_client_chap_enabled | default(false) %}
# Enable CHAP authentication
targetcli /iscsi/"${TARGET_IQN}"/tpg1 set attribute authentication=1
targetcli /iscsi/"${TARGET_IQN}"/tpg1 set attribute generate_node_acls=0

{% for initiator_iqn in iscsi_client_acls %}
# ACL for {{ initiator_iqn }}
if ! targetcli ls /iscsi/"${TARGET_IQN}"/tpg1/acls/{{ initiator_iqn }} &>/dev/null 2>&1; then
  targetcli /iscsi/"${TARGET_IQN}"/tpg1/acls create {{ initiator_iqn }}
fi
targetcli /iscsi/"${TARGET_IQN}"/tpg1/acls/{{ initiator_iqn }} \
  set auth userid={{ iscsi_client_chap_user }} password={{ iscsi_client_chap_password }}
{% endfor %}
{% else %}
# ACL-only mode (no CHAP — initiator IQN must match to connect)
targetcli /iscsi/"${TARGET_IQN}"/tpg1 set attribute authentication=0
targetcli /iscsi/"${TARGET_IQN}"/tpg1 set attribute generate_node_acls=0

{% for initiator_iqn in iscsi_client_acls %}
# ACL for {{ initiator_iqn }}
if ! targetcli ls /iscsi/"${TARGET_IQN}"/tpg1/acls/{{ initiator_iqn }} &>/dev/null 2>&1; then
  targetcli /iscsi/"${TARGET_IQN}"/tpg1/acls create {{ initiator_iqn }}
fi
{% endfor %}
{% endif %}

# ─── Seed ACL list on shared storage for failover sync ──────────────────────
# sync-iscsi-luns.sh reads this file after pool import to recreate ACLs on
# whichever node becomes active. One IQN per line. Edit this file (not
# targetcli) to add/remove initiators — changes take effect on next failover
# or manual sync run.
ACLS_DIR="/{{ zfs_pool_name }}/cluster-config/iscsi"
ACLS_FILE="${ACLS_DIR}/acls.conf"
mkdir -p "${ACLS_DIR}"
cat > "${ACLS_FILE}" <<'ACLS_EOF'
# Managed by Ansible — client iSCSI initiator ACLs
# One IQN per line. Edit to add/remove initiators.
# Changes apply on next failover or: bash /root/sync-iscsi-luns.sh
{% for initiator_iqn in iscsi_client_acls %}
{{ initiator_iqn }}
{% endfor %}
ACLS_EOF
chmod 0640 "${ACLS_FILE}"
echo "ACL list seeded at ${ACLS_FILE}"

targetcli saveconfig
echo "=== Client iSCSI target configured successfully ==="
