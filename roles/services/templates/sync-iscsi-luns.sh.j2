#!/bin/bash
# Managed by Ansible — Restore client-facing iSCSI LUNs from shared ZFS storage
#
# Called by Pacemaker (via systemd) after the ZFS pool imports on either node.
# Restores the exact LIO client config (LUN numbers, ACLs, CHAP) from shared
# storage instead of reconstructing from zvol enumeration, which would cause
# LUN reordering (breaks Kubernetes CSI PV mappings).
#
# Phases:
#   0    — TPG-to-VLAN mapping (baked in at Ansible deploy time)
#   0.5  — Decrypt CHAP credentials
#   1    — Merge local backend config with shared client config; extract current
#           backstore/LUN state for gap-fill (single Python pass)
#   1.5  — Restore merged config via targetcli
#   2    — Gap-fill: map any zvols not yet in restored config (crash window safety)
#   2.5  — Reapply per-TPG CHAP for generate_node_acls VLANs; save if changed
#   3    — Save updated config to shared storage
#
# Usage: bash /root/sync-iscsi-luns.sh
set -euo pipefail
{% set iscsi_vlans = client_vlans | selectattr('services', 'contains', 'iscsi') | list %}
{% set iscsi_vlan_count = iscsi_vlans | length %}

TARGET_IQN="{{ iscsi_client_iqn }}"
SHARED_CLIENT_CONFIG="/{{ zfs_pool_name }}/cluster-config/iscsi/client-saveconfig.json"

# ─── Phase 0: TPG-to-VLAN mapping (baked in at Ansible deploy time) ───────────
declare -A TPG_DATASET TPG_VLAN TPG_BS_PREFIX TPG_GEN_ACLS
{% for cv in iscsi_vlans %}
TPG_DATASET[{{ loop.index }}]="{{ cv.iscsi_dataset | default(iscsi_client_zvol_dataset) }}"
TPG_VLAN[{{ loop.index }}]="{{ cv.name }}"
TPG_BS_PREFIX[{{ loop.index }}]="{{ (cv.name + '-') if iscsi_vlan_count > 1 else '' }}"
TPG_GEN_ACLS[{{ loop.index }}]="{{ 'true' if (cv.generate_node_acls | default(false)) else 'false' }}"
{% endfor %}

# ─── Phase 0.5: Decrypt CHAP credentials ──────────────────────────────────────
# Populates CHAP_USER/CHAP_PASS (per-initiator) and TPG_CHAP_USER/TPG_CHAP_PASS (per-TPG)
. /root/iscsi-chap-decrypt.sh

echo "=== Syncing iSCSI LUNs for target: ${TARGET_IQN} ==="
{% for cv in iscsi_vlans %}
echo "    TPG{{ loop.index }}: VLAN={{ cv.name }}, dataset={{ cv.iscsi_dataset | default(iscsi_client_zvol_dataset) }}"
{% endfor %}

# ─── Phase 1: Merge configs and extract current state (single Python pass) ────
# Merges local backend config (disk backstores + non-client targets) with the
# shared client config (zvol backstores + client target), writes the result to
# MERGED_CONFIG, and emits BS|name| / LUN|tpg|index| records to PARSED_STATE
# for gap-fill — all in one pass to avoid re-reading the merged file.
echo ""
echo "--- Phase 1: Merge and parse config ---"

if [ ! -f "${SHARED_CLIENT_CONFIG}" ]; then
    echo "ERROR: ${SHARED_CLIENT_CONFIG} not found."
    echo "       Run /root/setup-client-iscsi-target.sh first, or redeploy with --tags services."
    exit 1
fi

MERGED_CONFIG=$(mktemp /tmp/lio-merged-XXXXXX.json)
PARSED_STATE=$(mktemp /tmp/lio-parsed-XXXXXX.txt)
trap 'rm -f "${MERGED_CONFIG}" "${PARSED_STATE}"' EXIT

python3 - > "${PARSED_STATE}" << PYEOF
import json, sys

LOCAL_CONFIG  = "{{ _iscsi_saveconfig_path }}"
CLIENT_CONFIG = "${SHARED_CLIENT_CONFIG}"
OUTPUT        = "${MERGED_CONFIG}"
CLIENT_IQN    = "${TARGET_IQN}"

# Load configs (local may be empty/absent on first deploy)
local_cfg  = {}
client_cfg = {}

try:
    with open(LOCAL_CONFIG) as f:
        local_cfg = json.load(f)
except FileNotFoundError:
    pass

with open(CLIENT_CONFIG) as f:
    client_cfg = json.load(f)

# Backend entries: from local config, exclude client-side entries
backend_storage = [
    obj for obj in local_cfg.get("storage_objects", [])
    if not obj.get("dev", "").startswith("/dev/zvol/")
]
backend_targets = [
    t for t in local_cfg.get("targets", [])
    if t.get("wwn") != CLIENT_IQN
]

# Client entries: from shared config (zvol backstores + client target)
client_storage = client_cfg.get("storage_objects", [])
client_targets = client_cfg.get("targets", [])

merged = {
    "fabric_modules":  client_cfg.get("fabric_modules",
                        local_cfg.get("fabric_modules", [])),
    "storage_objects": backend_storage + client_storage,
    "targets":         backend_targets + client_targets,
}

with open(OUTPUT, "w") as f:
    json.dump(merged, f, indent=2)

bs_count  = len(client_storage)
tpg_count = sum(len(t.get("tpgs", [])) for t in client_targets)
print(f"  Merged: {len(backend_storage)} backend + {bs_count} client backstores, "
      f"{len(client_targets)} client target(s), {tpg_count} TPG(s)", file=sys.stderr)

# Emit BS and LUN records for gap-fill phase (stdout → PARSED_STATE)
for bs in merged.get("storage_objects", []):
    if bs.get("plugin") == "block" and bs.get("dev", "").startswith("/dev/zvol/"):
        name = bs.get("name", "")
        if name:
            print(f"BS|{name}|")

for t in merged.get("targets", []):
    if t.get("wwn") == CLIENT_IQN:
        for tpg in t.get("tpgs", []):
            tpg_tag = tpg.get("tag", 0)
            for lun in tpg.get("luns", []):
                lun_index = lun.get("index", 0)
                print(f"LUN|{tpg_tag}|{lun_index}")
        break
PYEOF

# ─── Phase 1.5: Restore merged config ─────────────────────────────────────────
echo "  Restoring merged config via targetcli..."
targetcli restoreconfig "${MERGED_CONFIG}"
echo "  Config restored."

# ─── Phase 2: Gap-fill — map zvols created since the last save ────────────────
# Covers the sub-second window between a targetcli save and a crash.
# New LUNs get explicit number = max(existing LUN in TPG) + 1 to prevent reordering.
echo ""
echo "--- Phase 2: Gap-fill (zvols not in restored config) ---"

GAP_COMMANDS=()
HAS_GAP_FILL=false

# Parse restored state: existing backstores and per-TPG max LUN numbers
declare -A EXISTING_BS   # bs_name → 1
declare -A TPG_MAX_LUN   # tpg_tag → max LUN index seen

while IFS='|' read -r _type _key _val; do
    case "$_type" in
        BS)  EXISTING_BS["$_key"]=1 ;;
        LUN) # _key=tpg_tag, _val=lun_index
            cur="${TPG_MAX_LUN[$_key]:-0}"
            if [ "$_val" -gt "$cur" ] 2>/dev/null; then
                TPG_MAX_LUN["$_key"]="$_val"
            fi
            ;;
    esac
done < "${PARSED_STATE}"

for tpg_tag in $(seq 1 "${#TPG_DATASET[@]}"); do
    vlan_name="${TPG_VLAN[$tpg_tag]}"
    dataset="${TPG_DATASET[$tpg_tag]}"
    bs_prefix="${TPG_BS_PREFIX[$tpg_tag]}"
    zvol_dev_base="/dev/zvol/{{ zfs_pool_name }}/${dataset}"

    if [ ! -d "$zvol_dev_base" ]; then
        continue
    fi

    for zvol_path in "${zvol_dev_base}"/*; do
        [ -b "$zvol_path" ] || continue

        zvol_name=$(basename "$zvol_path")
        bs_name="${bs_prefix}${zvol_name}"

        if [[ "${EXISTING_BS[$bs_name]+_}" ]]; then
            continue  # already in restored config
        fi

        HAS_GAP_FILL=true
        # Assign next LUN number explicitly to avoid reordering
        next_lun=$(( ${TPG_MAX_LUN[$tpg_tag]:-0} + 1 ))
        TPG_MAX_LUN[$tpg_tag]="$next_lun"

        echo "  + Gap-fill: backstore ${bs_name} → ${zvol_path} (LUN ${next_lun} in tpg${tpg_tag})"
        GAP_COMMANDS+=("/backstores/block create ${bs_name} ${zvol_path}")
        GAP_COMMANDS+=("/iscsi/${TARGET_IQN}/tpg${tpg_tag}/luns create /backstores/block/${bs_name} ${next_lun}")
    done
done

if [ "$HAS_GAP_FILL" = "true" ]; then
    GAP_COMMANDS+=("saveconfig")
    printf '%s\n' "${GAP_COMMANDS[@]}" | targetcli
    echo "  Gap-fill applied and LIO config saved."
else
    echo "  No gap-fill needed — restored config is complete."
fi

# ─── Phase 2.5: Reapply per-TPG CHAP for generate_node_acls VLANs ────────────
# Reapplied from the freshly-decrypted env file each run so that credential
# rotations take effect immediately without needing a saveconfig → shared storage
# round-trip. A saveconfig is called when CHAP is applied so that Phase 3 writes
# the current credentials (not stale ones from the restored config) to shared
# storage.
echo ""
echo "--- Phase 2.5: Per-TPG CHAP (generate_node_acls VLANs) ---"
chap_applied=false
for tpg_tag in $(seq 1 "${#TPG_DATASET[@]}"); do
    if [ "${TPG_GEN_ACLS[$tpg_tag]}" = "true" ] && [[ "${TPG_CHAP_USER[$tpg_tag]+_}" ]]; then
        echo "  + Setting TPG-level CHAP and authentication=1 for tpg${tpg_tag}"
        targetcli <<< "/iscsi/${TARGET_IQN}/tpg${tpg_tag} set attribute authentication=1"
        # Wrap userid/password in single quotes for targetcli's shlex parser so that
        # values containing spaces, $, or other metacharacters are passed intact.
        # Embedded single quotes are escaped as '\''.
        _cu="${TPG_CHAP_USER[$tpg_tag]}"
        _cp="${TPG_CHAP_PASS[$tpg_tag]}"
        _chap_cmd="/iscsi/${TARGET_IQN}/tpg${tpg_tag} set auth userid='${_cu//\'/\'\\\'\'}' password='${_cp//\'/\'\\\'\'}'"
        targetcli <<< "$_chap_cmd"
        unset _chap_cmd _cu _cp
        chap_applied=true
    fi
done
if [ "$chap_applied" = "false" ]; then
    echo "  (no per-TPG CHAP configured)"
else
    # Persist CHAP updates to saveconfig.json so Phase 3 writes current
    # credentials to shared storage (not the stale values from the restored config).
    targetcli saveconfig
    echo "  Per-TPG CHAP saved to LIO config."
fi

# ─── Phase 3: Save updated config to shared storage ───────────────────────────
echo ""
echo "--- Phase 3: Save to shared storage ---"
/root/iscsi-save-client-config.py

echo ""
echo "=== iSCSI LUN sync complete ==="
