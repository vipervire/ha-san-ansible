#!/bin/bash
# Managed by Ansible — Auto-discover zvols and map as client-facing iSCSI LUNs
#
# This script is called by Pacemaker (via systemd) after the ZFS pool imports.
# It ensures every zvol under each iSCSI VLAN's dataset has a corresponding LIO
# backstore and LUN mapping in that VLAN's TPG — regardless of how the zvol was
# created: ZFS-over-iSCSI Proxmox plugin, Houston Cockpit UI, manual
# 'zfs create -V', or Ansible.
#
# Per-VLAN TPG design:
#   - Each iSCSI-enabled client VLAN has its own TPG with isolated LUN namespace
#   - Backstore naming: single-VLAN = <zvol_name>; multi-VLAN = <vlan>-<zvol_name>
#   - ACLs are read from acls-<vlan-name>.conf on shared storage (per-TPG)
#   - TPG-to-VLAN mapping is baked in at Ansible deploy time (no runtime file dep)
#
# Safe to re-run: idempotent. Adds missing LUNs, removes stale backstores,
# never touches zvols.
#
# Usage: bash /root/sync-iscsi-luns.sh
set -euo pipefail
{% set iscsi_vlans = client_vlans | selectattr('services', 'contains', 'iscsi') | list %}
{% set iscsi_vlan_count = iscsi_vlans | length %}

TARGET_IQN="{{ iscsi_client_iqn }}"
TOTAL_TPGS={{ iscsi_vlan_count }}

# ─── Phase 0: TPG-to-VLAN mapping (baked in at Ansible deploy time) ───────────
# Avoids runtime file dependency for TPG→dataset/VLAN mapping.
# Single-VLAN deployments use no backstore prefix (backward-compatible with
# zvols created before per-VLAN TPGs). Multi-VLAN uses <vlan>- prefix to
# prevent VMID collisions (e.g. two Proxmox clusters both creating vm-100-disk-0).
declare -A TPG_DATASET TPG_VLAN TPG_BS_PREFIX TPG_GEN_ACLS
{% for cv in iscsi_vlans %}
TPG_DATASET[{{ loop.index }}]="{{ cv.iscsi_dataset | default(iscsi_client_zvol_dataset) }}"
TPG_VLAN[{{ loop.index }}]="{{ cv.name }}"
TPG_BS_PREFIX[{{ loop.index }}]="{{ (cv.name + '-') if iscsi_vlan_count > 1 else '' }}"
TPG_GEN_ACLS[{{ loop.index }}]="{{ 'true' if (cv.generate_node_acls | default(false)) else 'false' }}"
{% endfor %}

# ─── Decrypt CHAP credentials ─────────────────────────────────────────────
# CHAP_USER["tpg:iqn"] / CHAP_PASS["tpg:iqn"] — per-initiator (ACL-mode VLANs)
# TPG_CHAP_USER["tpg"] / TPG_CHAP_PASS["tpg"] — per-TPG (generate_node_acls VLANs)
declare -A CHAP_USER CHAP_PASS TPG_CHAP_USER TPG_CHAP_PASS
if [ -f /root/.iscsi-chap.env.enc ]; then
  eval "$(openssl enc -d -aes-256-cbc -pbkdf2 -pass file:/etc/machine-id \
    -in /root/.iscsi-chap.env.enc 2>/dev/null)" || {
    echo "WARNING: Failed to decrypt CHAP credentials — CHAP will not be applied"
  }
fi

echo "=== Syncing iSCSI LUNs for target: ${TARGET_IQN} ==="
{% for cv in iscsi_vlans %}
echo "    TPG{{ loop.index }}: VLAN={{ cv.name }}, dataset={{ cv.iscsi_dataset | default(iscsi_client_zvol_dataset) }}"
{% endfor %}

# ─── Phase 1: Parse saveconfig.json (one python3 invocation) ──────────────────
# Each targetcli spawn costs 1-3s (Python init + rtslib load). Parsing
# saveconfig.json directly avoids N spawns for existence checks.
#
# Output format (pipe-delimited):
#   TARGET_EXISTS|<0|1>
#   BS|<backstore-name>|<dev-path>         (one per block backstore, global)
#   LUN|<tpg_tag>|<backstore-name>         (one per LUN mapping, per-TPG)
#   ACL|<tpg_tag>|<initiator-iqn>          (one per ACL, per-TPG)

declare -A EXISTING_BS     # backstore name → device path (global)
declare -A EXISTING_LUNS   # "tpg_tag:bs_name" → 1 (per-TPG LUN mappings)
declare -A EXISTING_ACLS   # "tpg_tag:iqn" → 1 (per-TPG ACLs)
TARGET_EXISTS=0

while IFS='|' read -r _type _key _val; do
    case "$_type" in
        TARGET_EXISTS) TARGET_EXISTS="$_key" ;;
        BS)            EXISTING_BS["$_key"]="$_val" ;;
        LUN)           EXISTING_LUNS["${_key}:${_val}"]=1 ;;
        ACL)           EXISTING_ACLS["${_key}:${_val}"]=1 ;;
    esac
done < <(ISCSI_TARGET="${TARGET_IQN}" python3 - << 'PYEOF'
import json, sys, os

saveconfig = '/etc/rtslib-fb-target/saveconfig.json'
target_iqn = os.environ.get('ISCSI_TARGET', '')

if not os.path.exists(saveconfig):
    print('TARGET_EXISTS|0')
    sys.exit(0)

with open(saveconfig) as f:
    config = json.load(f)

# Global backstores (shared across all TPGs in LIO)
for bs in config.get('storage_objects', []):
    if bs.get('plugin') == 'block':
        name = bs.get('name', '')
        dev = bs.get('dev', '')
        if name:
            print(f'BS|{name}|{dev}')

# Find our target and extract per-TPG LUNs and ACLs
target_found = False
for t in config.get('targets', []):
    if t.get('wwn') == target_iqn and t.get('fabric') == 'iscsi':
        target_found = True
        for tpg in t.get('tpgs', []):
            tpg_tag = tpg.get('tag', 0)
            # Per-TPG LUN → backstore mappings
            for lun in tpg.get('luns', []):
                storage_object = lun.get('storage_object', '')
                # storage_object format: /backstores/block/<name>
                bs_name = storage_object.split('/')[-1] if storage_object else ''
                if bs_name:
                    print(f'LUN|{tpg_tag}|{bs_name}')
            # Per-TPG ACLs
            for acl in tpg.get('node_acls', []):
                iqn = acl.get('node_wwn', '')
                if iqn:
                    print(f'ACL|{tpg_tag}|{iqn}')
        break

print('TARGET_EXISTS|1' if target_found else 'TARGET_EXISTS|0')
PYEOF
)

# Verify target exists (must have been created by setup-client-iscsi-target.sh)
if [ "$TARGET_EXISTS" != "1" ]; then
    echo "ERROR: iSCSI target ${TARGET_IQN} does not exist."
    echo "       Run /root/setup-client-iscsi-target.sh first."
    exit 1
fi

# ─── Collect all changes; apply in a single targetcli batch ───────────────────
# Reduces N separate process spawns (one per zvol/ACL) to exactly 1.
COMMANDS=()

# ─── Phase 2: Per-TPG zvol scanning ───────────────────────────────────────────
for tpg_tag in $(seq 1 "$TOTAL_TPGS"); do
    vlan_name="${TPG_VLAN[$tpg_tag]}"
    dataset="${TPG_DATASET[$tpg_tag]}"
    bs_prefix="${TPG_BS_PREFIX[$tpg_tag]}"
    zvol_parent="{{ zfs_pool_name }}/${dataset}"
    zvol_dev_base="/dev/zvol/${zvol_parent}"

    echo ""
    echo "--- Phase 2: TPG${tpg_tag} (VLAN=${vlan_name}, dataset=${dataset}) ---"

    if [ ! -d "$zvol_dev_base" ]; then
        echo "  (no zvol directory at ${zvol_dev_base} — no iSCSI zvols yet)"
        continue
    fi

    for zvol_path in "${zvol_dev_base}"/*; do
        # Skip subdirectories (nested datasets) — only direct child zvols
        [ -b "$zvol_path" ] || continue

        zvol_name=$(basename "$zvol_path")
        bs_name="${bs_prefix}${zvol_name}"
        lun_key="${tpg_tag}:${bs_name}"

        # Add missing backstore (global in LIO — created once, mapped per-TPG)
        if [[ ! "${EXISTING_BS[$bs_name]+_}" ]]; then
            echo "  + Adding backstore: ${bs_name} → ${zvol_path}"
            COMMANDS+=("/backstores/block create ${bs_name} ${zvol_path}")
            COMMANDS+=("/iscsi/${TARGET_IQN}/tpg${tpg_tag}/luns create /backstores/block/${bs_name}")
        # Add missing LUN mapping in this TPG (backstore exists but not mapped here)
        elif [[ ! "${EXISTING_LUNS[$lun_key]+_}" ]]; then
            echo "  + Adding LUN mapping to tpg${tpg_tag}: ${bs_name}"
            COMMANDS+=("/iscsi/${TARGET_IQN}/tpg${tpg_tag}/luns create /backstores/block/${bs_name}")
        fi
    done

    # Remove stale backstores owned by this TPG's dataset (zvol was deleted)
    # Only considers backstores with this VLAN's prefix and dev path under our dataset.
    for bs_name in "${!EXISTING_BS[@]}"; do
        # Skip backstores not belonging to this VLAN (wrong prefix)
        [[ "$bs_name" == "${bs_prefix}"* ]] || continue
        zvol_name="${bs_name#$bs_prefix}"
        expected_dev="${zvol_dev_base}/${zvol_name}"
        bs_dev="${EXISTING_BS[$bs_name]}"
        if [ ! -b "$expected_dev" ] && [[ "$bs_dev" == /dev/zvol/${zvol_parent}/* ]]; then
            # Guard against silent batch failure: targetcli batch mode returns exit code 0
            # even when a delete is rejected internally (e.g. backstore still has active
            # LUN mappings). Check EXISTING_LUNS before queuing so the operator sees a
            # clear message instead of a misleading "LIO configuration saved" with the
            # backstore still present.
            bs_has_lun=false
            for lun_key in "${!EXISTING_LUNS[@]}"; do
                if [[ "$lun_key" == *":${bs_name}" ]]; then
                    bs_has_lun=true
                    break
                fi
            done
            if [ "$bs_has_lun" = "true" ]; then
                echo "  ! Skipping stale backstore ${bs_name}: active LUN mappings exist."
                echo "    Remove LUN mappings manually, then re-run: bash /root/sync-iscsi-luns.sh"
            else
                echo "  - Removing stale backstore: ${bs_name} (zvol deleted, no active LUNs)"
                COMMANDS+=("/backstores/block delete ${bs_name}")
            fi
        fi
    done
done

# ─── Phase 3: Per-TPG ACL sync from shared storage ────────────────────────────
# Authoritative ACL lists live on the ZFS pool so both nodes share them.
# Seeded by setup-client-iscsi-target.sh; editable directly without Ansible.
echo ""
echo "--- Phase 3: ACL sync ---"
ACLS_DIR="/{{ zfs_pool_name }}/cluster-config/iscsi"

for tpg_tag in $(seq 1 "$TOTAL_TPGS"); do
    vlan_name="${TPG_VLAN[$tpg_tag]}"
    if [ "${TPG_GEN_ACLS[$tpg_tag]}" = "true" ]; then
        echo "  (tpg${tpg_tag}/VLAN=${vlan_name}: generate_node_acls — skipping ACL sync)"
        # Apply TPG-level CHAP if credentials are available
        if [[ "${TPG_CHAP_USER[$tpg_tag]+_}" ]]; then
            echo "  + Setting TPG-level CHAP for tpg${tpg_tag}"
            COMMANDS+=("/iscsi/${TARGET_IQN}/tpg${tpg_tag} set auth userid=${TPG_CHAP_USER[$tpg_tag]} password=${TPG_CHAP_PASS[$tpg_tag]}")
        fi
        continue
    fi
    acl_file="${ACLS_DIR}/acls-${vlan_name}.conf"

    if [ ! -f "$acl_file" ]; then
        echo "  (no ACL file at ${acl_file} — skipping ACL sync for tpg${tpg_tag})"
        continue
    fi

    mapfile -t DESIRED_IQNS < <(grep -v '^\s*#' "$acl_file" | grep -v '^\s*$' || true)

    # Build O(1) lookup set for desired IQNs
    unset DESIRED_SET; declare -A DESIRED_SET
    for iqn in "${DESIRED_IQNS[@]}"; do
        [ -n "$iqn" ] || continue
        if [[ ! "$iqn" =~ ^iqn\.[0-9]{4}-[0-9]{2}\.[a-zA-Z0-9][-a-zA-Z0-9.]*:[a-zA-Z0-9._:-]+$ ]]; then
            echo "  WARNING: skipping invalid IQN in ${acl_file}: ${iqn}"
            continue
        fi
        DESIRED_SET["$iqn"]=1
    done

    # Add missing ACLs to this TPG
    for iqn in "${DESIRED_IQNS[@]}"; do
        [ -n "$iqn" ] || continue
        acl_key="${tpg_tag}:${iqn}"
        if [[ "${DESIRED_SET[$iqn]+_}" ]] && [[ ! "${EXISTING_ACLS[$acl_key]+_}" ]]; then
            echo "  + Adding ACL to tpg${tpg_tag}: ${iqn}"
            COMMANDS+=("/iscsi/${TARGET_IQN}/tpg${tpg_tag}/acls create ${iqn}")
            # Apply per-initiator CHAP if credentials are available
            chap_key="${tpg_tag}:${iqn}"
            if [[ "${CHAP_USER[$chap_key]+_}" ]]; then
                COMMANDS+=("/iscsi/${TARGET_IQN}/tpg${tpg_tag}/acls/${iqn} set auth userid=${CHAP_USER[$chap_key]} password=${CHAP_PASS[$chap_key]}")
            fi
        fi
    done

    # Remove stale ACLs from this TPG (present in LIO but not in acl file)
    for acl_key in "${!EXISTING_ACLS[@]}"; do
        [[ "$acl_key" == "${tpg_tag}:"* ]] || continue
        existing_iqn="${acl_key#${tpg_tag}:}"
        if [[ ! "${DESIRED_SET[$existing_iqn]+_}" ]]; then
            echo "  - Removing stale ACL from tpg${tpg_tag}: ${existing_iqn}"
            COMMANDS+=("/iscsi/${TARGET_IQN}/tpg${tpg_tag}/acls delete ${existing_iqn}")
        fi
    done
done

# ─── Phase 4: Apply all changes in a single targetcli batch ───────────────────

if [ ${#COMMANDS[@]} -gt 0 ]; then
    COMMANDS+=("saveconfig")
    printf '%s\n' "${COMMANDS[@]}" | targetcli
    echo "=== LIO configuration saved ==="
else
    echo "=== No changes needed — all LUNs and ACLs in sync ==="
fi
