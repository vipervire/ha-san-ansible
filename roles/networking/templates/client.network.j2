# Managed by Ansible — client interface configuration
# Client VLAN: NFS, SMB, iSCSI client traffic (jumbo frames)
[Match]
Name={{ net_client_parent }}

[Network]
Address={{ client_ip }}/{{ vlans.client.subnet.split('/')[1] }}
VLAN=client-vlan

[Link]
MTUBytes={{ vlans.client.mtu | default(9000) }}
